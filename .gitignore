# ============================================================
# .gitignore - Sistema de Control de Insumos (Laboratorio Química UAJMS)
# ============================================================

# --- Entornos virtuales de Python ---
.venv/
venv/
env/
ENV/

# --- Cachés y bytecode de Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo

# --- Base de datos (no versionar datos reales del laboratorio) ---
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm
data/*.db

# --- Build de PyInstaller / distribución ---
build/
dist/
*.spec
*.manifest

# --- Logs y temporales ---
*.log
*.tmp
*.bak

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo

# --- Sistema operativo ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# --- Configuración local de Claude (mantener fuera del repo) ---
.claude/settings.local.json

# --- Variables de entorno sensibles ---
.env
.env.local
